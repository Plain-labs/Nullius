{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "typeRoots": ["../sdk/types", "./node_modules/@types"],
    "paths": {
      "@nullius/sdk": ["../sdk/src/index.ts"]
    }
  },
  "include": ["src", "../sdk/src/vendor.d.ts"],
  "exclude": ["node_modules", "../sdk/node_modules"]
}
